{
  "name": "astro-quiet-paper",
  "description": "Astro starter — quiet paper marketing site + React demo islands (@lifanh/quiet-paper)",
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://astro-quiet-paper.lifanh.workers.dev/",
  "keywords": [
    "astro",
    "astro-template",
    "cloudflare-workers",
    "markdown",
    "personal-site",
    "quiet-paper"
  ],
  "cloudflare": {
    "label": "Astro quiet-paper",
    "products": [
      "Workers"
    ],
    "categories": [],
    "publish": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifanh/astro-quiet-paper.git"
  },
  "bugs": {
    "url": "https://github.com/lifanh/astro-quiet-paper/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node src/lib/markdown/mermaid.js --check-cache && astro build",
    "check": "astro check",
    "lint": "oxlint .",
    "mermaid:prune": "node src/lib/markdown/mermaid.js --prune",
    "preview": "astro preview",
    "preview:worker": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@lifanh/quiet-paper": "^0.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-satteri": "^0.3.3",
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "@tailwindcss/typography": "^0.5.20",
    "oxlint": "^1.72.0",
    "puppeteer": "^25.3.0",
    "satteri": "^0.9.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.0.0"
  }
}
