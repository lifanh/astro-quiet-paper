---
import { render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPublishedPosts,
  postPath,
  postSlug,
} from "../../lib/posts";
import { site } from "../../site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getPublishedPosts();
const currentPostIndex = posts.findIndex((item) => item.id === post.id);
const newerPost = currentPostIndex > 0 ? posts[currentPostIndex - 1] : undefined;
const olderPost = currentPostIndex >= 0 ? posts[currentPostIndex + 1] : undefined;
---

<BaseLayout
  title={`${post.data.title} · ${site.name}`}
  description={post.data.description}
  ogType="article"
>
  <article class="max-w-measure">
    <p class="font-ui m-0 text-sm">
      <a href="/writing">← Writing</a>
    </p>

    <header class="mt-8">
      <p class="font-ui m-0 text-xs text-muted">
        <time datetime={post.data.date.toISOString()}>
          {formatPostDate(post.data.date)}
        </time>
      </p>
      <h1 class="m-0 mt-3 text-3xl leading-tight">{post.data.title}</h1>
      <p class="m-0 mt-5 text-lg leading-relaxed text-muted">
        {post.data.description}
      </p>
    </header>

    <div
      class="post-content mt-10 text-lg leading-relaxed"
    >
      <Content />
    </div>

    {
      (olderPost || newerPost) && (
        <nav
          class="mt-12 grid gap-4 border-t border-border-subtle pt-8 font-ui text-sm sm:grid-cols-2"
          aria-label="Adjacent posts"
        >
          <div>
            {olderPost && (
              <a href={postPath(olderPost)} rel="prev">
                <span class="block text-xs text-muted">Older post</span>
                <span>← {olderPost.data.title}</span>
              </a>
            )}
          </div>
          <div class="sm:text-right">
            {newerPost && (
              <a href={postPath(newerPost)} rel="next">
                <span class="block text-xs text-muted">Newer post</span>
                <span>{newerPost.data.title} →</span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</BaseLayout>
