---
import { render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPublishedPosts,
  postSlug,
} from "../../lib/posts";
import { site } from "../../site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} · ${site.name}`}
  description={post.data.description}
  ogType="article"
>
  <article class="max-w-measure">
    <p class="font-ui m-0 text-sm">
      <a href="/writing">← Writing</a>
    </p>

    <header class="mt-8">
      <p class="font-ui m-0 text-xs text-muted">
        <time datetime={post.data.date.toISOString()}>
          {formatPostDate(post.data.date)}
        </time>
      </p>
      <h1 class="m-0 mt-3 text-3xl leading-tight">{post.data.title}</h1>
      <p class="m-0 mt-5 text-lg leading-relaxed text-muted">
        {post.data.description}
      </p>
    </header>

    <div
      class="mt-10 text-lg leading-relaxed [&_a]:break-words [&_blockquote]:border-l [&_blockquote]:border-border [&_blockquote]:pl-5 [&_code]:font-mono [&_code]:text-sm [&_h2]:mb-3 [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:leading-tight [&_li+li]:mt-2 [&_p]:m-0 [&_p+p]:mt-5 [&_ul]:my-5 [&_ul]:pl-6"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
