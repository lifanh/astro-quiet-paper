---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site";
---

<BaseLayout
  title={`Page not found · ${site.name}`}
  description="A quiet 404 page for routes that are not part of this starter."
>
  <section class="max-w-measure" aria-labelledby="page-title">
    <p class="font-ui m-0 text-xs uppercase tracking-[0.16em] text-muted">
      404
    </p>
    <h1 id="page-title" class="m-0 mt-3 text-2xl leading-tight">
      Page not found
    </h1>
    <p class="m-0 mt-5 text-lg leading-relaxed text-muted">
      This route is not part of the quiet-paper starter. Try the homepage or the writing index.
    </p>
    <p class="m-0 mt-8 text-lg leading-relaxed">
      <a href="/">Home</a> · <a href="/writing">Writing</a>
    </p>
  </section>
</BaseLayout>
